# Set up your SMTP Email credentials here.
# For Gmail, you must generate an "App Password" bypassing 2FA.
# Copy this file to '.env.local' and add your precise keys.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="E-waste Workshop Team" <your_email@gmail.com>
